#!/usr/bin/env bash
set -euo pipefail

source "${HOME}/.local/opt/codex-desktop-linux/lib/codex-desktop-linux/common.sh"

ensure_layout
load_install_config
load_metadata

source_head="$(source_repo_head 2>/dev/null || true)"
if [ -z "$source_head" ]; then
    source_head="${SOURCE_REPO_HEAD-}"
fi

if ! evaluate_update_status; then
    status=$?
    if [ "$status" -eq 10 ]; then
        :
    else
        echo "Could not evaluate update status."
        exit 1
    fi
else
    status=0
fi

remote_etag="${EVAL_REMOTE_ETAG-}"
remote_last_modified="${UPDATE_REMOTE_LAST_MODIFIED-}"
remote_content_length="${UPDATE_REMOTE_CONTENT_LENGTH-}"

echo "Install root: $OPT_ROOT"
echo "Source repo:  $SOURCE_REPO_DIR"
echo "Build repo:   ${REPO_DIR:-$(effective_repo_dir)}"
echo "Build repo head:     ${EVAL_BUILD_HEAD-}"
echo "Source repo head:    ${source_head:-unavailable}"
echo "Wrapper repo remote: ${EVAL_REMOTE_HEAD-}"
echo "Source overlay sha:  ${EVAL_SOURCE_OVERLAY_SHA:-none}"
echo "Cached DMG etag:     ${DMG_ETAG-untracked}"
echo "Remote DMG etag:     ${remote_etag:-unknown}"
echo "Cached DMG modified: ${DMG_LAST_MODIFIED-untracked}"
echo "Remote DMG modified: ${remote_last_modified:-unknown}"

if [ "$status" -eq 0 ]; then
    load_update_status
    clear_outdated_install_tags
    echo "Status: up to date"
    exit 0
fi

tag_outdated_install \
    "$EVAL_BUILD_HEAD" \
    "$EVAL_REMOTE_HEAD" \
    "$EVAL_REMOTE_ETAG" \
    "$EVAL_SOURCE_OVERLAY_SHA"

echo "Status: update available"
if [ "${UPDATE_REPO_UPSTREAM_CHANGED:-0}" -eq 1 ]; then
    echo "Reason: wrapper repo upstream changed"
fi
if [ "${UPDATE_REPO_OVERLAY_CHANGED:-0}" -eq 1 ]; then
    echo "Reason: source overlay changed"
fi
if [ "${UPDATE_DMG_CHANGED:-0}" -eq 1 ]; then
    echo "Reason: Codex.dmg changed"
fi
exit 10
